# Local development reverse proxy. Production deployments should use their own
# Caddyfile (or other ingress) with a real hostname for automatic TLS, plus any
# security headers appropriate for the deployed app.

:3000

encode zstd gzip

reverse_proxy /api* backend:3000 {
  header_up Host {http.reverse_proxy.upstream.host}
}

reverse_proxy frontend:3000 {
    header_up Host {http.reverse_proxy.upstream.host}
    flush_interval -1
}
