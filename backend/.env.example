# Backend environment — used when DJANGO_CONFIGURATION=Production.
# Local development reads safe defaults from backend/backend/settings/local.py
# and does not need any of these.

DJANGO_CONFIGURATION=Production
DJANGO_SETTINGS_MODULE=backend.settings

# Required in Production (django-configurations enforces this with environ_required=True)
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DATABASE_URL=postgres://user:pass@host:5432/dbname
VALKEY_URL=redis://host:6379
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
