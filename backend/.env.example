# Backend environment — used when DJANGO_CONFIGURATION=Production.
# Local development reads safe defaults from backend/backend/settings/local.py
# and does not need any of these.

DJANGO_CONFIGURATION=Production
DJANGO_SETTINGS_MODULE=backend.settings

# Required in Production (django-configurations enforces this with environ_required=True).
# Generate a fresh secret key with:
#   python -c 'import secrets; print(secrets.token_urlsafe(64))'
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DATABASE_URL=postgres://user:pass@host:5432/dbname
VALKEY_URL=redis://host:6379
DJANGO_ALLOWED_HOSTS=example.com,www.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Email. Allauth password reset and "mandatory" email verification require a
# real backend. Defaults to console:// (logs only) if unset.
# Examples:
#   submission://user:pass@smtp.example.com:587
#   smtp+tls://user:pass@smtp.example.com:587
DJANGO_EMAIL_URL=console://
DJANGO_DEFAULT_FROM_EMAIL=noreply@example.com
DJANGO_SERVER_EMAIL=root@example.com

# Optional security overrides (defaults shown).
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_SECURE_HSTS_SECONDS=31536000
# DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# DJANGO_SECURE_HSTS_PRELOAD=True
